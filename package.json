{
  "name": "claude-code-cli-voiceInter",
  "version": "1.0.0",
  "description": "Claude Code CLI Web UI with Voice Interaction",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"vite\"",
    "server": "node server/index.js",
    "client": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "start:daemon": "nohup node server/index.js > logs/server.log 2>&1 & echo $! > logs/server.pid && echo 'Server started in background. PID saved to logs/server.pid'",
    "stop:daemon": "if [ -f logs/server.pid ]; then kill $(cat logs/server.pid) && rm logs/server.pid && echo 'Server stopped'; else echo 'No server.pid file found'; fi",
    "restart:daemon": "npm run stop:daemon && npm run start:daemon",
    "restart": "lsof -ti:3001 | xargs kill -9 2>/dev/null; lsof -ti:3000 | xargs kill -9 2>/dev/null; sleep 1 && npm run dev",
    "logs": "tail -f logs/server.log",
    "dev:lan": "HOST=0.0.0.0 concurrently \"node server/index.js\" \"vite --host\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src server",
    "lint:fix": "eslint src server --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\" \"server/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\" \"server/**/*.js\"",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "docker:build": "docker build -t claude-voiceinter .",
    "docker:run": "docker run -p 3001:3001 -p 3000:3000 claude-voiceinter",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down",
    "docker:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.59",
    "@tailwindcss/postcss": "^4.2.3",
    "autoprefixer": "^10.5.0",
    "express": "^4.18.2",
    "lucide-react": "^1.8.0",
    "multer": "^2.1.1",
    "node-pty": "^1.1.0",
    "postcss": "^8.5.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "homepage": "https://github.com/lg320531124/claude-code-cli-voiceInter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lg320531124/claude-code-cli-voiceInter.git"
  }
}
