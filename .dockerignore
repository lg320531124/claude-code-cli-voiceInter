# Claude Code CLI VoiceInter - Docker ignore
# Exclude unnecessary files from Docker build

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs (will be generated in container)
dist
build
coverage

# Development files
.git
.gitignore
.github
.vscode
.idea
*.md
!README.md

# Environment files
.env
.env.*
!.env.example

# Logs
logs
*.log

# Test files
src/__tests__
vitest.config.js
*.test.js
*.spec.js

# Documentation
docs
*.md

# OS files
.DS_Store
Thumbs.db

# Temporary files
tmp
temp
*.tmp
*.swp
*.swo