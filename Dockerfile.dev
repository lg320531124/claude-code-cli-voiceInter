# Claude Code CLI VoiceInter - Development Dockerfile
# Hot reload enabled for development

FROM node:22-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy source files
COPY . .

# Create logs directory
RUN mkdir -p logs

# Environment configuration
ENV NODE_ENV=development
ENV HOST=0.0.0.0

# Expose all ports
EXPOSE 3001 3000 5173

# Start development server
CMD ["npm", "run", "dev:lan"]