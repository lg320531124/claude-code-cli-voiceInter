# Claude Code CLI VoiceInter - Environment Configuration
# Copy this file to .env and customize values

# ============================================
# Server Configuration
# ============================================

# Server port (default: 3001)
PORT=3001

# Server host (default: localhost)
# Use 0.0.0.0 for LAN access
HOST=localhost

# ============================================
# VoiceMode Services (Local STT/TTS)
# ============================================

# Whisper.cpp STT endpoint (default: port 2022)
# Start with: voicemode service whisper start
WHISPER_ENDPOINT=http://127.0.0.1:2022/v1

# Kokoro TTS endpoint (default: port 8880)
# Start with: voicemode service kokoro start
KOKORO_ENDPOINT=http://127.0.0.1:8880/v1

# ============================================
# Claude CLI Configuration
# ============================================

# Claude CLI command path (default: 'claude')
# Use full path if claude is not in PATH
CLAUDE_PATH=claude

# Project path for Claude session
# Claude will operate in this directory
PROJECT_PATH=/Users/lg/project/claude-code-cli-voiceInter

# ============================================
# Optional: Production Settings
# ============================================

# Node environment
NODE_ENV=development

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================
# Voice Settings (Frontend defaults)
# ============================================

# Default TTS voice
# Kokoro: af_sky, af_bella, af_sarah, am_adam, bf_emma, bm_george
DEFAULT_VOICE=af_sky

# Default speech rate (0.5 - 2.0)
DEFAULT_SPEED=1.0

# Default language
# auto, zh-CN, en-US, ja-JP, ko-KR, etc.
DEFAULT_LANGUAGE=auto

# ============================================
# WebSocket Configuration
# ============================================

# Heartbeat interval (ms)
HEARTBEAT_INTERVAL=30000

# Max reconnect attempts
MAX_RECONNECT_ATTEMPTS=5

# Reconnect base delay (ms)
RECONNECT_BASE_DELAY=1000

# ============================================
# Cache Configuration
# ============================================

# Max TTS audio cache entries
MAX_TTS_CACHE_SIZE=100

# Cache expiry time (ms, default 24 hours)
CACHE_EXPIRY=86400000

# ============================================
# Service Recovery
# ============================================

# Health check interval (ms)
HEALTH_CHECK_INTERVAL=10000

# Max recovery attempts
MAX_RECOVERY_ATTEMPTS=5

# Recovery base delay (ms)
RECOVERY_BASE_DELAY=1000